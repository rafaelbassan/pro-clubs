# =============================================================================
# Pro Clubs — variáveis de ambiente
# Copie para .env na raiz:  cp .env.example .env
# =============================================================================

# --- Postgres (externo — obrigatório) ---
DATABASE_URL=postgresql://usuario:senha@seu-servidor:5432/proclubs

# --- Redis (externo — obrigatório) ---
REDIS_URL=redis://seu-servidor:6379/0
# Com senha: redis://:senha@seu-servidor:6379/0
# Com user:   redis://usuario:senha@seu-servidor:6379/0

# --- API (FastAPI) ---
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000
TIMEZONE=America/Sao_Paulo
CACHE_TTL_SECONDS=300
SEARCH_CACHE_TTL_SECONDS=3600

# API_PORT / WEB_PORT — só com infra/docker-compose.override.yml (dev local)

# --- Web (Next.js) ---
INTERNAL_API_URL=http://api:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# --- EA (403 em VPS) — deixe vazio para auto-detect do container warp ---
# EA_PROXY_BASE_URL=
# EA_HTTP_PROXY=socks5h://warp:1080
# EA_PROXY_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Produção (Coolify) — exemplo
# =============================================================================
# DATABASE_URL=postgresql://proclubs:senha@161.97.92.62:5432/proclubs
# REDIS_URL=redis://161.97.92.62:6379/0
# JWT_SECRET=<openssl rand -hex 32>
# CORS_ORIGINS=https://proclubs.seudominio.com
# NEXTAUTH_URL=https://proclubs.seudominio.com
# NEXTAUTH_SECRET=<openssl rand -hex 32>
# INTERNAL_API_URL=http://api:8000

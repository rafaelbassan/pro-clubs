# =============================================================================
# Pro Clubs — variáveis de ambiente
# Copie para .env na raiz:  cp .env.example .env
# Usado por: docker compose (-f infra/docker-compose.yml) e Coolify
# =============================================================================

# --- Postgres ---
POSTGRES_USER=proclubs
POSTGRES_PASSWORD=proclubs
POSTGRES_DB=proclubs

# POSTGRES_PORT só para dev local com override (ver infra/docker-compose.override.example.yml)
# --- API (FastAPI) ---
# Dentro do Docker use host "postgres". Se mudar POSTGRES_PASSWORD, atualize DATABASE_URL também.
DATABASE_URL=postgresql://proclubs:proclubs@postgres:5432/proclubs
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000
TIMEZONE=America/Sao_Paulo
CACHE_TTL_SECONDS=300
SEARCH_CACHE_TTL_SECONDS=3600
API_PORT=8000

# --- Web (Next.js) ---
INTERNAL_API_URL=http://api:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production
WEB_PORT=3000

# --- OAuth (opcional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Produção (Coolify) — exemplo
# =============================================================================
# POSTGRES_PASSWORD=senha-forte-aqui
# DATABASE_URL=postgresql://proclubs:senha-forte-aqui@postgres:5432/proclubs
# JWT_SECRET=<openssl rand -hex 32>
# CORS_ORIGINS=https://proclubs.seudominio.com
# NEXTAUTH_URL=https://proclubs.seudominio.com
# NEXTAUTH_SECRET=<openssl rand -hex 32>
# INTERNAL_API_URL=http://api:8000
